{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "SandboxManagerConfig": {
    "TargetNamespace": "sandbox-containers",
    "RuntimeClassName": "gvisor",
    "DefaultResourceRequests": {
      "MemoryMi": 256,
      "CpuMillicores": 250
    },
    "DefaultResourceLimits": {
      "MemoryMi": 512,
      "CpuMillicores": 500
    },
    "PodNamePrefix": "sandbox",
    "DefaultImage": "192.168.0.140:5555/donkeywork-agents/sandbox-executor:2a24d01",
    "ImagePullPolicy": "IfNotPresent",
    "PodReadyTimeoutSeconds": 90,
    "IdleTimeoutMinutes": 60,
    "CleanupCheckIntervalMinutes": 1,
    "MaxTotalContainers": 50,
    "EnableAuthProxy": false,
    "AuthProxyImage": "192.168.0.140:5555/donkeywork-agents/sandbox-authproxy:9922332",
    "McpServerImage": "192.168.0.140:5555/donkeywork-agents/sandbox-executor:2a24d01",
    "McpPodNamePrefix": "mcp",
    "McpIdleTimeoutMinutes": 60,
    "McpMaxContainerLifetimeMinutes": 480,
    "McpDefaultResourceRequests": {
      "MemoryMi": 128,
      "CpuMillicores": 250
    },
    "McpDefaultResourceLimits": {
      "MemoryMi": 256,
      "CpuMillicores": 500
    }
  }
}
