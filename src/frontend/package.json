{
  "name": "frontend",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @donkeywork/web dev",
    "build": "pnpm --filter @donkeywork/web build",
    "lint": "pnpm --filter @donkeywork/web lint",
    "preview": "pnpm --filter @donkeywork/web preview",
    "test": "pnpm --filter @donkeywork/web test",
    "test:ui": "pnpm --filter @donkeywork/web test:ui",
    "test:run": "pnpm --filter @donkeywork/web test:run"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@chevrotain/regexp-to-ast": "^11.2.0",
    "chevrotain": "^11.2.0",
    "chevrotain-allstar": "^0.3.1",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-languageserver-types": "^3.17.5",
    "vscode-uri": "^3.1.0"
  }
}
