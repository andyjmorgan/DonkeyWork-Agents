{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Authentication": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning",
        "DonkeyWork": "Debug"
      }
    }
  },
  "Persistence": {
    "ConnectionString": "Host=localhost;Port=5433;Database=donkeywork_agents;Username=donkeywork;Password=donkeywork_dev",
    "EncryptionKey": "dev-encryption-key-change-in-production"
  },
  "Keycloak": {
    "Authority": "https://auth.donkeywork.dev/realms/Agents",
    "Audience": "donkeywork-agents-api",
    "RequireHttpsMetadata": true,
    "FrontendUrl": "http://localhost:5199"
  },
  "Storage": {
    "ServiceUrl": "http://files.donkeywork.dev:8333",
    "PublicServiceUrl": "https://files.donkeywork.dev",
    "AccessKey": "admin",
    "SecretKey": "admin",
    "DefaultBucket": "files",
    "DefaultShareExpiry": "1.00:00:00",
    "DefaultPresignedUrlExpiry": "01:00:00",
    "FileDeletionGracePeriod": "30.00:00:00",
    "UsePathStyleAddressing": true
  },
  "Agents": {
    "ExecutionTimeout": "00:20:00",
    "StreamRetention": "1.00:00:00"
  },
  "Nats": {
    "Url": "nats://localhost:4222",
    "StreamName": "executions",
    "SubjectPrefix": "execution",
    "MaxAge": "1.00:00:00"
  },
  "Anthropic": {
    "ApiKey": "",
    "DefaultModelId": "claude-sonnet-4-6"
  },
  "Actors": {
    "ResponseTimeoutMinutes": 25
  },
  "Sandbox": {
    "ManagerBaseUrl": "http://localhost:8080"
  },
  "Scheduling": {
    "DefaultTimeZone": "Europe/Dublin",
    "ExecutionHistoryRetentionDays": 30,
    "MinimumCronIntervalHours": 4,
    "CompletedOneOffRetentionDays": 7
  },
  "OAuth": {
    "TokenRefreshCheckInterval": "00:05:00",
    "TokenRefreshWindow": "00:10:00",
    "MaxRefreshRetries": 3,
    "RefreshRetryDelay": "00:01:00"
  }
}
